generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Live menu (storefront reads this directly; admin edits in place).
model Menu {
  id           String            @id @default(cuid())
  slug         String            @unique
  name         String
  description  String?
  price        Decimal           @db.Decimal(10, 2)
  image        String?
  isFavorite   Boolean           @default(false)
  available    Boolean           @default(true)
  /// Max total quantity that can be sold (all-time). Null = unlimited.
  maxQuantity  Int?
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  orderItems   OrderItem[]
  optionGroups MenuOptionGroup[]
}

model MenuOptionGroup {
  id          String       @id @default(cuid())
  menuId      String
  menu        Menu         @relation(fields: [menuId], references: [id], onDelete: Cascade)
  sortOrder   Int          @default(0)
  name        String
  required    Boolean      @default(false)
  multiSelect Boolean      @default(false)
  options     MenuOption[]
}

model MenuOption {
  id         String          @id @default(cuid())
  groupId    String
  group      MenuOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sortOrder  Int             @default(0)
  label      String
  priceDelta Decimal         @default(0) @db.Decimal(10, 2)
}

model Order {
  id           String       @id @default(cuid())
  slugId       String       @unique
  customerName String
  phone        String
  type         OrderType
  /// Full street address when type is DELIVERY.
  deliveryAddress String?
  /// Gate, unit, landmarks (optional) when type is DELIVERY.
  deliveryNotes   String?
  status       OrderStatus  @default(RECEIVED)
  batchId      String?
  batch        OrderBatch?  @relation(fields: [batchId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  /// Checkout selection: pay at pickup vs online transfer + receipt.
  paymentChoice         PaymentChoice         @default(PAY_LATER)
  /// Set when PAY_NOW: URL to uploaded payment proof (same host as /uploads).
  paymentReceiptUrl     String?
  orderItems   OrderItem[]
  appFeedbacks AppFeedback[]
}

/// Optional post-checkout remarks about the storefront experience (linked to order when provided).
model AppFeedback {
  id        String   @id @default(cuid())
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([orderId])
}

enum OrderType {
  PICKUP
  DELIVERY
}

enum OrderStatus {
  RECEIVED
  PREPARING
  READY
  DELIVERED
}

/// How the customer intends to pay (checkout modal).
enum PaymentChoice {
  PAY_LATER
  PAY_NOW
}

enum OrderBatchStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

/// A time window when customers may order (live menu applies; capacity is per batch).
model OrderBatch {
  id              String           @id @default(cuid())
  label           String?
  fulfillmentDate DateTime         @db.Date
  opensAt         DateTime
  closesAt        DateTime
  maxItems        Int
  status          OrderBatchStatus @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  orders          Order[]
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  quantity          Int
  menuId            String
  menu              Menu     @relation(fields: [menuId], references: [id])
  remarks           String?
  unitPrice         Decimal  @db.Decimal(10, 2)
  selectedOptions   Json?
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model SystemSettings {
  id                      String   @id @default(cuid())
  maxOrdersPerDay         Int      @default(15)
  orderingEnabled         Boolean  @default(true)
  minimumDeliveryAmount   Decimal? @db.Decimal(10, 2)
  /// Admin storefront display name (sidebar, optional public use).
  companyName             String?
  /// URL from POST /uploads/image (admin).
  companyLogoUrl          String?
  /// Payment transfer QR shown at checkout (uploaded image / SVG URL).
  paymentQrUrl            String?
  /// WhatsApp number for admin new-order alerts (E.164 e.g. +60123456789). Overrides .env fallback.
  adminWhatsappNumber     String?
  updatedAt               DateTime @updatedAt
}
