DATABASE_URL="postgresql://user:password@localhost:5432/bun_theory?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
PORT=3001

# Twilio WhatsApp (use sandbox "From" while testing, e.g. whatsapp:+14155238886)
TWILIO_ACCOUNT_SID=""
# Use either Auth Token OR API Key + Secret (restricted keys need both key vars + Account SID)
TWILIO_AUTH_TOKEN=""
# TWILIO_API_KEY_SID=""
# TWILIO_API_KEY_SECRET=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Fallback when Admin phone is not set in Admin → Settings → Company info (DB).
# E.164 or whatsapp:+...
ADMIN_WHATSAPP_NUMBER="whatsapp:+60123456789"

# Storage (S3/R2 compatible)
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="bun-theory-uploads"
S3_REGION="auto"
# Base URL for stored files (local /uploads, or R2 public dev URL / custom domain when using R2)
PUBLIC_URL="http://localhost:3001/uploads"
