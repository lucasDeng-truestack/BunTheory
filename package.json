{
  "name": "bun-theory",
  "version": "1.0.0",
  "private": true,
  "description": "Bun Theory by Bakar & Roast",
  "scripts": {
    "dev": "concurrently -n \"backend,frontend\" -c \"blue,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run start:dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:frontend": "npm --prefix frontend ci --include=dev && npm --prefix frontend run build",
    "build:backend": "npm --prefix backend ci --include=dev && npm --prefix backend run build",
    "start": "concurrently -n \"backend,frontend\" -c \"blue,magenta\" \"npm run start:backend\" \"npm run start:frontend\"",
    "start:frontend": "cd frontend && npm run start",
    "start:backend": "cd backend && npm run start:prod",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:seed": "cd backend && npm run db:seed",
    "db:studio": "cd backend && npx prisma studio",
    "db:generate": "cd backend && npx prisma generate",
    "db:reset": "cd backend && npx prisma migrate reset --force",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
	"docker:down:volumes": "docker compose down -v",
    "lint": "npm run lint:frontend",
    "lint:frontend": "cd frontend && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
