NEXT_PUBLIC_API_URL=http://localhost:3001
# Optional: fallback QR URL if none is set in Admin → Settings → Payment QR (defaults to /public/images/payment-qr.svg)
# NEXT_PUBLIC_PAYMENT_QR_URL=https://example.com/qr.png
# Optional: E.164 without spaces, e.g. +60123456789 — used for "Send receipt on WhatsApp" pre-filled chat after checkout
# NEXT_PUBLIC_CUSTOMER_WHATSAPP_E164=+60123456789
